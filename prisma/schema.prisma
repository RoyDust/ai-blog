// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum CommentStatus {
  APPROVED
  PENDING
  REJECTED
  SPAM
}

enum PostSummaryStatus {
  EMPTY
  QUEUED
  GENERATING
  GENERATED
  FAILED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]
  accounts      Account[]
  sessions      Session[]
  aiApiClients  AiApiClient[]

  @@map("users")
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?
  summaryStatus PostSummaryStatus @default(EMPTY)
  summaryError  String?   @db.Text
  summaryGeneratedAt DateTime?
  summaryJobId String?
  summaryModelId String?
  coverImage  String?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  viewCount   Int       @default(0)
  readingTimeMinutes Int @default(1)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        Tag[]
  comments    Comment[]
  likes       Like[]
  bookmarks   Bookmark[]
  aiDraftBinding AiDraftBinding?

  @@index([authorId])
  @@index([categoryId])
  @@index([published, createdAt])
  @@index([featured, createdAt])
  @@index([deletedAt])
  @@index([summaryStatus])
  @@index([summaryJobId])
  @@map("posts")
}

model AiApiClient {
  id          String    @id @default(cuid())
  name        String
  tokenPrefix String    @unique
  tokenHash   String    @unique
  scopes      String[]
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  drafts      AiDraftBinding[]

  @@index([ownerId])
  @@index([revokedAt])
  @@map("ai_api_clients")
}

model AiDraftBinding {
  id         String      @id @default(cuid())
  clientId   String
  client     AiApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  postId     String      @unique
  post       Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  externalId String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([clientId, externalId])
  @@index([clientId])
  @@map("ai_draft_bindings")
}

model AiModel {
  id                  String    @id @default(cuid())
  name                String
  description         String?   @db.Text
  provider            String    @default("openai-compatible")
  baseUrl             String
  requestPath         String    @default("/chat/completions")
  model               String
  apiKey              String?   @db.Text
  capabilities        String[]  @default(["post-summary"])
  isDefaultForSummary Boolean   @default(false)
  enabled             Boolean   @default(true)
  lastTestedAt        DateTime?
  lastTestStatus      String?
  lastTestMessage     String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([enabled])
  @@index([isDefaultForSummary])
  @@map("ai_models")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  posts       Post[]

  @@index([deletedAt])
  @@map("categories")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  color     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  posts     Post[]

  @@index([deletedAt])
  @@map("tags")
}

model Comment {
  id          String        @id @default(cuid())
  content     String        @db.Text
  status      CommentStatus @default(APPROVED)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  postId      String
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  browserId   String?
  authorLabel String?
  parentId    String?
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]     @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([browserId])
  @@index([deletedAt])
  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  browserId String?

  @@unique([postId, userId])
  @@unique([postId, browserId])
  @@index([postId])
  @@index([browserId])
  @@map("likes")
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("bookmarks")
}
