// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum CommentStatus {
  APPROVED
  PENDING
  REJECTED
  SPAM
}

enum PostSummaryStatus {
  EMPTY
  QUEUED
  GENERATING
  GENERATED
  FAILED
}

enum AiNewsRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum AiNewsRunTrigger {
  MANUAL
  CRON
}

enum AiNewsSourceType {
  RSS
  HACKERNEWS
  GITHUB_RELEASES
  GITHUB_TRENDING_RSS
  REDDIT
}

enum NotificationType {
  COMMENT_CREATED
  COMMENT_PENDING
  COMMENT_REPLY
  AI_TASK_SUCCEEDED
  AI_TASK_FAILED
  AI_TASK_PARTIAL_FAILED
  AI_NEWS_SUCCEEDED
  AI_NEWS_FAILED
  SYSTEM_WARNING
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  posts        Post[]
  comments     Comment[]
  likes        Like[]
  bookmarks    Bookmark[]
  accounts     Account[]
  sessions     Session[]
  aiApiClients AiApiClient[]
  aiTasks      AiTask[]
  notificationReceipts NotificationRecipient[]
  apiOperationLogs ApiOperationLog[]

  @@map("users")
}

model Post {
  id                 String            @id @default(cuid())
  title              String
  slug               String            @unique
  content            String            @db.Text
  excerpt            String?
  seoTitle           String?
  seoDescription     String?           @db.Text
  seoGeneratedAt     DateTime?
  seoModelId         String?
  summaryStatus      PostSummaryStatus @default(EMPTY)
  summaryError       String?           @db.Text
  summaryGeneratedAt DateTime?
  summaryJobId       String?
  summaryModelId     String?
  coverImage         String?
  coverAssetId       String?
  published          Boolean           @default(false)
  featured           Boolean           @default(false)
  viewCount          Int               @default(0)
  readingTimeMinutes Int               @default(1)
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  publishedAt        DateTime?

  authorId       String
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  coverAsset     CoverAsset?     @relation(fields: [coverAssetId], references: [id], onDelete: SetNull)
  categoryId     String?
  category       Category?       @relation(fields: [categoryId], references: [id])
  tags           Tag[]
  comments       Comment[]
  likes          Like[]
  bookmarks      Bookmark[]
  visitLogs      VisitLog[]
  aiDraftBinding AiDraftBinding?
  aiTaskItems    AiTaskItem[]

  @@index([authorId])
  @@index([categoryId])
  @@index([published, createdAt])
  @@index([featured, createdAt])
  @@index([coverAssetId])
  @@index([deletedAt])
  @@index([summaryStatus])
  @@index([summaryJobId])
  @@index([seoGeneratedAt])
  @@map("posts")
}

model VisitLog {
  id        String   @id @default(cuid())
  path      String
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  referrer  String?
  userAgent String?
  ipHash    String?
  visitorId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([postId])
  @@index([visitorId])
  @@map("visit_logs")
}

model ApiOperationLog {
  id            String   @id @default(cuid())
  requestId     String
  method        String
  path          String
  route         String?
  scope         String
  operation     String?
  statusCode    Int?
  success       Boolean
  durationMs    Int?
  actorType     String?
  actorUserId   String?
  actorUser     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorClientId String?
  actorLabel    String?
  ipHash        String?
  userAgent     String?  @db.Text
  query         Json?
  requestBody   Json?
  errorName     String?
  errorMessage  String?  @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([requestId])
  @@index([method, createdAt])
  @@index([statusCode, createdAt])
  @@index([success, createdAt])
  @@index([path, createdAt])
  @@index([actorUserId, createdAt])
  @@map("api_operation_logs")
}

model SystemSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model CoverAsset {
  id          String    @id @default(cuid())
  url         String    @unique
  key         String?
  provider    String    @default("qiniu")
  source      String    @default("upload")
  status      String    @default("active")
  title       String?
  alt         String?
  description String?   @db.Text
  tags        String[]  @default([])
  width       Int?
  height      Int?
  blurDataUrl String?   @db.Text
  aiPrompt    String?   @db.Text
  aiModelId   String?
  metadata    Json?
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  posts Post[]

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([deletedAt])
  @@map("cover_assets")
}

model AiApiClient {
  id          String    @id @default(cuid())
  name        String
  tokenPrefix String    @unique
  tokenHash   String    @unique
  scopes      String[]
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  drafts AiDraftBinding[]

  @@index([ownerId])
  @@index([revokedAt])
  @@map("ai_api_clients")
}

model AiDraftBinding {
  id         String      @id @default(cuid())
  clientId   String
  client     AiApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  postId     String      @unique
  post       Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  externalId String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([clientId, externalId])
  @@index([clientId])
  @@map("ai_draft_bindings")
}

model AiModel {
  id                  String    @id @default(cuid())
  name                String
  description         String?   @db.Text
  provider            String    @default("openai-compatible")
  baseUrl             String
  requestPath         String    @default("/chat/completions")
  model               String
  apiKey              String?   @db.Text
  capabilities        String[]  @default(["post-summary"])
  isDefaultForSummary Boolean   @default(false)
  isDefaultForCoverImage Boolean @default(false)
  enabled             Boolean   @default(true)
  lastTestedAt        DateTime?
  lastTestStatus      String?
  lastTestMessage     String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([enabled])
  @@index([isDefaultForSummary])
  @@index([isDefaultForCoverImage])
  @@map("ai_models")
}

model AiTask {
  id             String    @id @default(cuid())
  type           String
  status         String
  source         String
  modelId        String?
  createdById    String?
  createdBy      User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  requestedCount Int       @default(0)
  succeededCount Int       @default(0)
  failedCount    Int       @default(0)
  startedAt      DateTime?
  finishedAt     DateTime?
  lastError      String?   @db.Text
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items AiTaskItem[]

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([createdById])
  @@map("ai_tasks")
}

model AiTaskItem {
  id            String    @id @default(cuid())
  taskId        String
  task          AiTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  postId        String?
  post          Post?     @relation(fields: [postId], references: [id], onDelete: SetNull)
  status        String
  action        String
  inputSnapshot Json?
  output        Json?
  applied       Boolean   @default(false)
  error         String?   @db.Text
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([taskId, status])
  @@index([postId])
  @@index([action, createdAt])
  @@map("ai_task_items")
}

model AiNewsRun {
  id            String          @id @default(cuid())
  runDate       DateTime
  trigger       AiNewsRunTrigger
  status        AiNewsRunStatus @default(RUNNING)
  sourceCount   Int             @default(0)
  failureCount  Int             @default(0)
  rawCandidateCount      Int     @default(0)
  dedupedCandidateCount  Int     @default(0)
  scoredCandidateCount   Int     @default(0)
  selectedCandidateCount Int     @default(0)
  sourceFailureJson      Json?
  qualityScore           Int?
  citationCoverage       Float?
  generationMode         String?
  error         String?         @db.Text
  postId        String?
  postTitle     String?
  postSlug      String?
  published     Boolean         @default(false)
  reviewVerdict String?
  reviewScore   Int?
  reviewSummary String?         @db.Text
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  durationMs    Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  candidates AiNewsCandidate[]

  @@index([createdAt])
  @@index([runDate])
  @@index([status])
  @@map("ai_news_runs")
}

model AiNewsSource {
  id         String           @id @default(cuid())
  type       AiNewsSourceType
  name       String
  url        String
  homepage   String?
  category   String?
  enabled    Boolean          @default(true)
  weight     Int              @default(1)
  minScore   Int?
  fetchLimit Int?
  config     Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  candidates AiNewsCandidate[]

  @@index([enabled, type])
  @@index([category])
  @@map("ai_news_sources")
}

model AiNewsCandidate {
  id              String           @id @default(cuid())
  runId           String
  run             AiNewsRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceId        String?
  source          AiNewsSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceType      AiNewsSourceType
  sourceName      String
  title           String
  url             String
  canonicalUrl    String
  summary         String?          @db.Text
  content         String?          @db.Text
  author          String?
  publishedAt     DateTime?
  metadata        Json?
  community       Json?
  aiScore         Float?
  aiReason        String?          @db.Text
  aiSummary       String?          @db.Text
  aiTags          String[]         @default([])
  aiRiskFlags     String[]         @default([])
  scoreError      String?          @db.Text
  duplicateOfId   String?
  duplicateOf     AiNewsCandidate? @relation("AiNewsCandidateDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates      AiNewsCandidate[] @relation("AiNewsCandidateDuplicates")
  selected        Boolean          @default(false)
  selectionReason String?          @db.Text
  enrichment      Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([runId])
  @@index([sourceId])
  @@index([sourceType])
  @@index([canonicalUrl])
  @@index([selected])
  @@index([duplicateOfId])
  @@map("ai_news_candidates")
}

model Notification {
  id         String               @id @default(cuid())
  type       NotificationType
  severity   NotificationSeverity @default(INFO)
  title      String
  body       String?              @db.Text
  actionUrl  String?
  entityType String?
  entityId   String?
  dedupeKey  String?              @unique
  metadata   Json?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  recipients NotificationRecipient[]

  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}

model NotificationRecipient {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId, readAt, createdAt])
  @@index([userId, dismissedAt, createdAt])
  @@map("notification_recipients")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  posts Post[]

  @@index([deletedAt])
  @@map("categories")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  color     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  posts Post[]

  @@index([deletedAt])
  @@map("tags")
}

model Comment {
  id        String        @id @default(cuid())
  content   String        @db.Text
  status    CommentStatus @default(APPROVED)
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  browserId   String?
  authorLabel String?
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([browserId])
  @@index([deletedAt])
  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId    String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  browserId String?

  @@unique([postId, userId])
  @@unique([postId, browserId])
  @@index([postId])
  @@index([browserId])
  @@map("likes")
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("bookmarks")
}
